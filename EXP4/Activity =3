# Input from user
marks = []
n = int(input("Enter number of students: "))

# loop to take marks
for i in range(1, n + 1):
    m = float(input("Enter marks: "))
    marks.append(m)

# calculate average
average = sum(marks) / len(marks)

# find topper marks
topper = max(marks)

# display result
print("\nAverage Marks:", average)
print("Topper Marks:", topper)
