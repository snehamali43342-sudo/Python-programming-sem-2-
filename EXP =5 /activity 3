# program to count frequency of items purchased
"""
Created on Tue Mar 17 11:04:22 2026

@author: sneha mali 
"""
items = input("Enter purchased items:").split()

frequency = {}

for item in items:
    if item in frequency:
        frequency[item] += 1
    else:
        frequency[item] = 1
        
print("Item Frequecy:", frequency)
