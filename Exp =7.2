# Create a student class that calculate grade
"""
Created on Tue Apr 21 16:52:37 2026

@author: sneha mali
"""

class Student:
    def __init__(self, name, marks):
        self.name = name
        self.marks = marks

    def calculate_grade(self):
        if self.marks >= 90:
            grade = "A"
        elif self.marks >= 75:
            grade = "B"
        elif self.marks >= 50:
            grade = "C"
        else:
            grade = "Fail"

        print("Student:", self.name)
        print("Grade:", grade)


# Example
s = Student("Amit", 82)
s.calculate_grade()
