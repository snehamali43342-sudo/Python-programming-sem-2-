# Handle invalid age input in registration form
"""
Created on Tue Apr 21 17:37:42 2026

@author: sneha mali
"""

try:
    age = int(input("Enter your age: "))

    if age <= 0 or age > 120:
        raise ValueError("Invalid Age Entered")

    print("Registration Successful")

except ValueError as e:
    print("Error:", e)
